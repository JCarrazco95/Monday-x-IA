# ===== monday =====
MONDAY_TOKEN=tu_token_de_api_v2_monday
AIRCALL_BOARD_ID=1234567890            # board donde entran las llamadas de Aircall
# IDs de columna del board de Aircall (los ves en Centro de desarrolladores > columnas):
COL_RECORDING=recording                # columna con la URL del mp3 (link/text)
COL_TRANSCRIPCION=transcripcion         # opcional: si Aircall ya manda transcript (long_text)
COL_VENDEDOR=persona                    # opcional: nombre/owner del vendedor
COL_PROSPECTO=name                      # opcional (name = titulo del item)
# columnas donde el handler ESCRIBE el resultado:
COL_ANALISIS_JSON=analisis             # long_text: JSON completo del agente (lo lee la pestana)
COL_SCORE=score                        # numbers: puntaje 0-100
COL_BANDA=banda                        # status/color: rojo|amarillo|verde
COL_ESTADO_PROC=estado_proc            # status: opcional (Pendiente/Analizando/Listo/Error)

# ===== Modelo (agente Sandler) =====
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6      # claude-opus-4-8 para maxima calidad

# ===== Transcripcion (solo si la fuente es audio) =====
TRANSCRIBE_PROVIDER=openai             # openai | none  (none = se asume que ya hay transcript)
OPENAI_API_KEY=sk-...
OPENAI_TRANSCRIBE_MODEL=whisper-1

# ===== Seguridad / server =====
MONDAY_SIGNING_SECRET=                 # opcional: firma del webhook para validar origen
PORT=8080
