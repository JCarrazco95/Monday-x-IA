# --- Servidor ---
PORT=4000
NODE_ENV=development

# --- Seguridad / operación ---
# Si defines API_KEY, TODA la API (menos /health y /webhooks) exige el header
# x-api-key con este valor. Sin ella, la API queda ABIERTA (solo dev/demo).
# En el frontend, define VITE_API_KEY con el mismo valor en el build.
API_KEY=
# Orígenes permitidos por CORS (lista separada por comas). Vacío = refleja el
# origen (dev). En producción pon el/los dominio(s) del frontend/Monday.
CORS_ORIGINS=
# Límites de tasa por IP (opcionales; defaults razonables).
RATE_LIMIT_API=1000       # general / 15 min
RATE_LIMIT_AI=100         # endpoints de IA y mutaciones / 5 min
RATE_LIMIT_WEBHOOK=300    # webhooks entrantes / 5 min
# Reutilizar el análisis de una llamada ya analizada (ahorra tokens). false lo desactiva.
CALL_ANALYSIS_CACHE=true
# Reintentos ante errores transitorios de la IA (429/5xx/timeout). 0 los desactiva.
AI_MAX_RETRIES=2
AI_RETRY_BASE_MS=1000

# --- Proveedor de IA ---
# Opcional. Si lo defines, fuerza el proveedor: claude | gemini | demo
# Si lo dejas vacío, se autodetecta por las API keys presentes:
#   ANTHROPIC_API_KEY -> claude | GEMINI_API_KEY -> gemini | (ninguna) -> demo
AI_PROVIDER=

# --- Anthropic (deploy) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Por defecto Haiku 4.5 (el más económico: $1/$5 por 1M tokens). Sube HEAVY a
# claude-sonnet-4-6 o claude-opus-4-8 si quieres más profundidad de análisis.
CLAUDE_MODEL_DEFAULT=claude-haiku-4-5
CLAUDE_MODEL_HEAVY=claude-haiku-4-5

# --- Google Gemini (pruebas gratis) ---
# Consigue una API key gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_HEAVY=gemini-2.5-flash

# --- Monday.com ---
MONDAY_API_TOKEN=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_BOARD_ID_LEADS=000000000
# Signing secret de la app de Monday. Si lo dejas vacío o "changeme", el webhook
# NO verifica firma (solo para pruebas). En producción pon el secret real.
MONDAY_WEBHOOK_SECRET=changeme
# Mapeo de columnas del board (opcional). Si el match por título no basta, pon
# aquí el ID de columna exacto (lo ves en la URL/API de tu board).
MONDAY_COL_NOMBRE=
MONDAY_COL_EMAIL=
MONDAY_COL_TELEFONO=
MONDAY_COL_RAZON_SOCIAL=
MONDAY_COL_RFC=
# Mapeo de columnas de SALIDA (clave lógica -> ID real de la columna en Monday).
# JSON en una línea. Solo se escriben las columnas mapeadas; lo no mapeado se OMITE
# (no se toca → no dispara automatizaciones ajenas). Sin esta variable = passthrough (dev/demo).
# Ej: {"score_lead":"numeric_mkp1","prioridad":"text_aa","requiere_atencion":"color_uu"}
MONDAY_COLUMN_MAP=

# --- Base de datos ---
# PRODUCCIÓN: define DATABASE_URL con un Postgres gestionado (Render/Neon/Supabase).
#   Formato: postgresql://usuario:password@host:5432/basededatos
#   Si está presente, el backend usa Postgres (durable, con respaldos).
DATABASE_URL=
# DESARROLLO LOCAL: si NO hay DATABASE_URL, se usa SQLite en este archivo.
DATABASE_PATH=./data/maxirent.db
# Verificación estricta del certificado SSL de Postgres (evita MITM). Pega el CA
# en PEM; o pon DATABASE_SSL_STRICT=true para exigir verificación sin CA propio.
DATABASE_CA_CERT=
DATABASE_SSL_STRICT=

# --- Scraper / prospección de leads ---
# Google Places API (oficial, legal). Búsqueda de empresas por sector + ciudad.
# Consíguela en https://console.cloud.google.com (habilita "Places API (New)").
# Tiene $200 USD/mes gratis. Sin esta key, la fuente devuelve datos de demo.
GOOGLE_PLACES_API_KEY=
# Lusha — proveedor B2B con cumplimiento (datos tipo LinkedIn, legal).
# Genera la API key en https://dashboard.lusha.com/enrich/api y pégala aquí.
# Flujo search→enrich; el enrich consume créditos de tu plan Lusha.
LUSHA_API_KEY=
# Opcionales (defaults razonables; cámbialos solo si tu plan usa otra versión):
# LUSHA_BASE_URL=https://api.lusha.com/prospecting
# LUSHA_SEARCH_PATH=/contact/search
# LUSHA_ENRICH_PATH=/contact/enrich
# LUSHA_REVEAL=true   # ponlo en false para probar la conexión SIN gastar créditos
# Scraping de directorios HTML: frágil y gris legalmente. Desactivado por defecto.
DIRECTORY_SCRAPER_ENABLED=false
# Grupo del board donde se crean los prospectos importados desde /prospeccion.
# (ID del grupo en Monday; "Prospección"). Si se omite, van al grupo por defecto.
MONDAY_GROUP_PROSPECCION=group_mm4s77d3

# --- Aircall (opcional, llamadas reales + transcripción) ---
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
AIRCALL_WEBHOOK_TOKEN=
DEEPGRAM_API_KEY=

# --- Tablero de llamadas de Aircall en Monday (sincronización) ---
# Aircall registra cada llamada como item en este board. Lo leemos para analizar.
# Sin MONDAY_BOARD_ID_CALLS, la sincronización queda desactivada.
MONDAY_BOARD_ID_CALLS=18398458590
# IDs de columna en ese board (ya traen los valores reales por defecto):
MONDAY_COL_CALL_ID=text_mm07x5tn
MONDAY_COL_CALL_LINK=link_mm07s8jf
MONDAY_COL_CALL_LEAD=board_relation_mm1whczc
# Máximo de llamadas NUEVAS a analizar por sincronización (control de costo IA).
CALLS_SYNC_MAX=25
# "De aquí en adelante": solo analiza llamadas iniciadas en/después de esta fecha
# (ISO). Ponlo en la fecha de arranque para IGNORAR todo el histórico. Ej:
CALLS_SYNC_SINCE=2026-07-03
# Columna de fecha de inicio en el tablero de llamadas (para ordenar/filtrar).
MONDAY_COL_CALL_DATE=date_mm07gzt1

# --- Inteligencia de gobierno (opcional) ---
GOV_API_URL=
GOV_API_KEY=

# --- Next Best Action (agente de seguimiento) ---
# "Cron" interno: corre el agente cada N horas y escribe alertas en Monday.
# Déjalo vacío para ejecutarlo solo bajo demanda (botón del panel / POST /api/nba/run).
NBA_CRON_HOURS=
# Umbrales de inactividad (horas) para levantar alertas (opcionales; defaults 24/72/24).
NBA_HORAS_CALIENTE=24
NBA_HORAS_TIBIA=72
NBA_HORAS_COMPROMISO=24

# --- Forecast / Pipeline ---
# Ticket base estimado (MXN/mes) por oportunidad típica; el forecast lo multiplica
# por un factor de tamaño según el score del lead. Sustituir por monto real cuando exista.
FORECAST_TICKET_BASE=25000
FORECAST_MONEDA=MXN