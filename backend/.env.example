# --- Servidor ---
PORT=4000
NODE_ENV=development

# --- Proveedor de IA ---
# Opcional. Si lo defines, fuerza el proveedor: claude | gemini | demo
# Si lo dejas vacío, se autodetecta por las API keys presentes:
#   ANTHROPIC_API_KEY -> claude | GEMINI_API_KEY -> gemini | (ninguna) -> demo
AI_PROVIDER=

# --- Anthropic (deploy) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
# Por defecto Haiku 4.5 (el más económico: $1/$5 por 1M tokens). Sube HEAVY a
# claude-sonnet-4-6 o claude-opus-4-8 si quieres más profundidad de análisis.
CLAUDE_MODEL_DEFAULT=claude-haiku-4-5
CLAUDE_MODEL_HEAVY=claude-haiku-4-5

# --- Google Gemini (pruebas gratis) ---
# Consigue una API key gratuita en https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_DEFAULT=gemini-2.5-flash
GEMINI_MODEL_HEAVY=gemini-2.5-flash

# --- Monday.com ---
MONDAY_API_TOKEN=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_BOARD_ID_LEADS=000000000
# Signing secret de la app de Monday. Si lo dejas vacío o "changeme", el webhook
# NO verifica firma (solo para pruebas). En producción pon el secret real.
MONDAY_WEBHOOK_SECRET=changeme
# Mapeo de columnas del board (opcional). Si el match por título no basta, pon
# aquí el ID de columna exacto (lo ves en la URL/API de tu board).
MONDAY_COL_NOMBRE=
MONDAY_COL_EMAIL=
MONDAY_COL_TELEFONO=
MONDAY_COL_RAZON_SOCIAL=
MONDAY_COL_RFC=
# Mapeo de columnas de SALIDA (clave lógica -> ID real de la columna en Monday).
# JSON en una línea. Solo se escriben las columnas mapeadas; lo no mapeado se OMITE
# (no se toca → no dispara automatizaciones ajenas). Sin esta variable = passthrough (dev/demo).
# Ej: {"score_lead":"numeric_mkp1","prioridad":"text_aa","requiere_atencion":"color_uu"}
MONDAY_COLUMN_MAP=

# --- Base de datos ---
# PRODUCCIÓN: define DATABASE_URL con un Postgres gestionado (Render/Neon/Supabase).
#   Formato: postgresql://usuario:password@host:5432/basededatos
#   Si está presente, el backend usa Postgres (durable, con respaldos).
DATABASE_URL=
# DESARROLLO LOCAL: si NO hay DATABASE_URL, se usa SQLite en este archivo.
DATABASE_PATH=./data/maxirent.db

# --- Scraper / prospección de leads ---
# Google Places API (oficial, legal). Búsqueda de empresas por sector + ciudad.
# Consíguela en https://console.cloud.google.com (habilita "Places API (New)").
# Tiene $200 USD/mes gratis. Sin esta key, la fuente devuelve datos de demo.
GOOGLE_PLACES_API_KEY=
# Proveedor B2B con cumplimiento (Apollo/Lusha/Cognism) para datos tipo LinkedIn.
# NO scrapeamos LinkedIn directamente (viola ToS + LFPDPPP). Hueco preparado:
# cuando se contrate un proveedor, se conecta su API y se activa con esta key.
B2B_PROVIDER_API_KEY=
# Scraping de directorios HTML: frágil y gris legalmente. Desactivado por defecto.
DIRECTORY_SCRAPER_ENABLED=false

# --- Aircall (opcional, llamadas reales + transcripción) ---
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
AIRCALL_WEBHOOK_TOKEN=
DEEPGRAM_API_KEY=

# --- Inteligencia de gobierno (opcional) ---
GOV_API_URL=
GOV_API_KEY=

# --- Next Best Action (agente de seguimiento) ---
# "Cron" interno: corre el agente cada N horas y escribe alertas en Monday.
# Déjalo vacío para ejecutarlo solo bajo demanda (botón del panel / POST /api/nba/run).
NBA_CRON_HOURS=
# Umbrales de inactividad (horas) para levantar alertas (opcionales; defaults 24/72/24).
NBA_HORAS_CALIENTE=24
NBA_HORAS_TIBIA=72
NBA_HORAS_COMPROMISO=24

# --- Forecast / Pipeline ---
# Ticket base estimado (MXN/mes) por oportunidad típica; el forecast lo multiplica
# por un factor de tamaño según el score del lead. Sustituir por monto real cuando exista.
FORECAST_TICKET_BASE=25000
FORECAST_MONEDA=MXN